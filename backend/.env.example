# Copy to .env (or export in your shell) and adjust. Everything has a sane
# default; secrets stay in env, never in code or the DB.

# --- Core ---
# STOCKS_DB_PATH=stocks.db
# STOCKS_LOG_LEVEL=INFO
# STOCKS_REFRESH_SECONDS=180

# --- Web security ---
# Comma-separated browser origins allowed to call the API (no wildcard —
# cookies ride on these requests).
# STOCKS_CORS_ORIGINS=http://localhost:5173
# Set to 1 when serving over HTTPS so session cookies are marked Secure.
# STOCKS_COOKIE_SECURE=0
# STOCKS_SESSION_TTL_SECONDS=1209600       # active session lifetime (14 days)
# STOCKS_PENDING_SESSION_TTL_SECONDS=300   # password-ok -> TOTP window

# --- Data sources ---
# SEC requires a descriptive User-Agent with contact info for fair access.
# STOCKS_SEC_USER_AGENT="Signal Dashboard you@example.com"
# Optional Alpha Vantage key (primary for technicals; Yahoo fallback if unset).
# STOCKS_ALPHA_VANTAGE_KEY=

# --- Economic calendar ---
# Optional Financial Modeling Prep key. When set, the calendar uses FMP's
# official Low/Medium/High impact ratings; unset falls back to Nasdaq's keyless
# endpoint with our own curated importance classification.
# STOCKS_FMP_KEY=
# STOCKS_ECON_CALENDAR_DAYS_AHEAD=7
# STOCKS_ECON_CALENDAR_DAYS_BACK=1
# STOCKS_ECON_CALENDAR_MIN_INTERVAL_SECONDS=3600
# Comma-separated country allowlist (empty string keeps every country).
# STOCKS_ECON_CALENDAR_COUNTRIES=United States

# --- X (Twitter) watcher ---
# Accounts to monitor (comma-separated, without the @).
# STOCKS_X_ACCOUNTS=realDonaldTrump,aistocksavvy
# Official X API v2 bearer token. When set, the source uses the official API and
# is stamped "ok". When unset, it falls back to unofficial Nitter-style RSS
# mirrors: the posts are still stored, but the source is flagged as an
# error-style warning until an official key is configured.
# STOCKS_X_BEARER=
# Nitter-style mirror base URLs (RSS served at {mirror}/{account}/rss).
# STOCKS_X_MIRRORS=https://nitter.net,https://nitter.poast.org,https://nitter.privacydev.net
# STOCKS_X_POSTS_LIMIT=30
# STOCKS_X_MIN_INTERVAL_SECONDS=900

# --- Email digest (SMTP; works with a Gmail app password) ---
# STOCKS_SMTP_HOST=
# STOCKS_SMTP_PORT=587
# STOCKS_SMTP_USER=
# STOCKS_SMTP_PASSWORD=
# STOCKS_SMTP_FROM=

# --- SMS digest (Twilio) ---
# STOCKS_TWILIO_ACCOUNT_SID=
# STOCKS_TWILIO_AUTH_TOKEN=
# STOCKS_TWILIO_FROM_PHONE=
